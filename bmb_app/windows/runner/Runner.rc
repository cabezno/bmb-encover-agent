#include "targetver.h"

#define IDR_MAINFRAME 128
#define IDM_ABOUTBOX 0x0010
#define IDD_ABOUTBOX 100
#define IDS_ABOUTBOX 101
#define IDD_MAIN_DIALOG 102

#define IDS_APP_TITLE                 "BMB Encover Agent"
#define IDS_HELLO                     "Bienvenido a BMB Encover Agent"

#define IDM_FILE_EXIT                 105
#define IDM_HELP_ABOUT               109

#define IDR_MAINFRAME                128
#define IDR_MAINICON                 201
#define IDR_APP_ICON                 202

#ifdef APSTUDIO_INVOKED
#ifndef APSTUDIO_READONLY_SYMBOLS
#define _APS_NEXT_RESOURCE_VALUE        129
#define _APS_NEXT_COMMAND_VALUE         32771
#define _APS_NEXT_CONTROL_VALUE         1000
#define _APS_NEXT_SYMED_VALUE           110
#endif
#endif

#include <windows.h>

/////////////////////////////////////////////////////////////////////////////
// English (United States) resources

#if !defined(AFX_RESOURCE_DLL) || defined(AFX_TARG_ENU)
#ifdef _WIN32
LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US
#pragma code_page(1252)
#endif //_WIN32

/////////////////////////////////////////////////////////////////////////////
// Icon
//

// Icon with lowest ID value placed first to ensure application icon
// remains consistent on all systems.
IDR_MAINICON           ICON                    "app_icon.ico"
IDR_APP_ICON           ICON                    "app_icon.ico"

/////////////////////////////////////////////////////////////////////////////
// Version
//

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 0,1,0,0
 PRODUCTVERSION 0,1,0,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "BlackMagicBox"
            VALUE "FileDescription", "BMB Encover Agent - Remote agent client"
            VALUE "FileVersion", "0.1.0.0"
            VALUE "InternalName", "bmb_app"
            VALUE "LegalCopyright", "Copyright (C) 2026 BlackMagicBox"
            VALUE "OriginalFilename", "bmb_app.exe"
            VALUE "ProductName", "BMB Encover Agent"
            VALUE "ProductVersion", "0.1.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

/////////////////////////////////////////////////////////////////////////////
// Dialog
//

IDD_ABOUTBOX DIALOGEX 0, 0, 200, 100
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About BMB Encover Agent"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    ICON            IDR_MAINICON,IDC_STATIC,10,10,20,20
    LTEXT           "BMB Encover Agent v0.1.0",IDC_STATIC,40,15,120,10
    LTEXT           "BlackMagicBox - Remote Agent Client",IDC_STATIC,40,30,120,10
    DEFPUSHBUTTON   "OK",IDOK,140,80,50,14
END

#endif    // English (United States) resources
